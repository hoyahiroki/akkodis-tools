{
  "extraKnownMarketplaces": {
    "akkodis-tools": {
      "source": {
        "source": "github",
        "repo": "hoyahiroki/akkodis-tools"
      }
    }
  },
  "enabledPlugins": {
    "akkodis-skills@akkodis-tools": true,
    "dev-tools@akkodis-tools": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
